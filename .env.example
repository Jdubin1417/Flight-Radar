# Copy this file to ".env" and fill in values, or just export these in your shell.
#
# EASIEST WAY: you don't need to edit this file at all — launch the app
# (npm start), open http://localhost:8787, and click "⚙️ Settings" to paste your
# keys right in the browser. They're saved here automatically.

# OPTIONAL: free key from https://aisstream.io  (Sign up -> create API key)
# Without it, the ship/sea layer stays empty but planes + satellites still work.
AISSTREAM_API_KEY=

# OPTIONAL: free OpenSky account raises the aircraft rate limit substantially.
# Create an API client at https://opensky-network.org (Account -> API clients)
# and paste the client id + secret here. Without it, planes still load globally
# but OpenSky throttles anonymous use after a while (last snapshot is kept).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# OPTIONAL: free key from https://openweathermap.org (sign up -> API keys).
# Enables the 🌦️ Rain overlay: modeled precipitation for the WHOLE world —
# the 🌧️ Radar overlay only covers regions with ground weather radar.
OWM_API_KEY=

# OPTIONAL: change the port the local server listens on
PORT=8787
